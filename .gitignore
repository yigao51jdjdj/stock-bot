# 股票数据抓取机器人 .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# 日志
*.log
logs/
log/

# 临时文件
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# 操作系统文件
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# 本地配置（包含敏感信息）
.env
.env.local
config.local.json
config.json

# 数据文件
data/*.json
data/*.csv
!data/.gitkeep

# 依赖
node_modules/
package-lock.json

# GitHub Actions
.github/workflows/*.local.yml

# 测试文件
test_*.py
quick_test.py
test_api.py